[
    {{- range $index, $page := where .Site.RegularPages "Section" "recipe" -}}
        {{- if $index }},{{ end }}
        {{- $contentParts := slice $page.Plain -}}
        {{- if eq $page.Params.schemaversion 1 -}}
            {{- range $page.Params.ingredientgroups -}}
                {{- with .name }}{{ $contentParts = append . $contentParts }}{{ end -}}
                {{- range .ingredients -}}
                    {{- $contentParts = append .name $contentParts -}}
                    {{- with .note }}{{ $contentParts = append . $contentParts }}{{ end -}}
                    {{- range .options -}}
                        {{- $contentParts = append .name $contentParts -}}
                        {{- with .note }}{{ $contentParts = append . $contentParts }}{{ end -}}
                    {{- end -}}
                {{- end -}}
            {{- end -}}
            {{- range $page.Params.steps -}}
                {{- with .group }}{{ $contentParts = append . $contentParts }}{{ end -}}
                {{- $contentParts = append .text $contentParts -}}
                {{- range .timers -}}
                    {{- with .label }}{{ $contentParts = append . $contentParts }}{{ end -}}
                    {{- with .durationText }}{{ $contentParts = append . $contentParts }}{{ end -}}
                {{- end -}}
                {{- range .temperatures -}}
                    {{- with .mode }}{{ $contentParts = append . $contentParts }}{{ end -}}
                    {{- with .note }}{{ $contentParts = append . $contentParts }}{{ end -}}
                {{- end -}}
                {{- range .equipmentSettings -}}
                    {{- with .kind }}{{ $contentParts = append . $contentParts }}{{ end -}}
                    {{- with .mode }}{{ $contentParts = append . $contentParts }}{{ end -}}
                    {{- with .note }}{{ $contentParts = append . $contentParts }}{{ end -}}
                {{- end -}}
            {{- end -}}
        {{- end -}}
        {{- $durationMinutes := 0 -}}
        {{- $hasDuration := false -}}
        {{- range slice "preptimeminutes" "resttimeminutes" "cooktimeminutes" -}}
            {{- if isset $page.Params . -}}
                {{- $durationMinutes = add $durationMinutes (index $page.Params .) -}}
                {{- $hasDuration = true -}}
            {{- end -}}
        {{- end -}}
        {
            "title": {{ $page.Title | jsonify }},
            "content": {{ delimit $contentParts " " | jsonify }},
            "permalink": {{ $page.Permalink | jsonify }},
            "summary": {{ $page.Summary | jsonify }},
            "tags": {{ $page.Params.tags | jsonify }},
            "description": {{ $page.Params.description | jsonify }},
            "aka": {{ $page.Params.aka | jsonify }},
            "prepTimeMinutes": {{ $page.Params.preptimeminutes | jsonify }},
            "restTimeMinutes": {{ $page.Params.resttimeminutes | jsonify }},
            "cookTimeMinutes": {{ $page.Params.cooktimeminutes | jsonify }},
            "durationMinutes": {{ if $hasDuration }}{{ $durationMinutes }}{{ else }}null{{ end }},
            "nutrition": {{ $page.Params.nutrition | jsonify }},
            "images": {
                {{ if $page.Params.image }}
                {{ $thumbPath := replace $page.Params.image "images/recipes/" "_gen/images/recipes/thumbnails/" }}
                {{ $originalPath := $page.Params.image }}
                "thumb": {{ $thumbPath | jsonify }},
                "full": {{ $originalPath | jsonify }}
                {{ else }}
                "thumb": null,
                "full": null
                {{ end }}
            }
        }
    {{- end -}}
    ]
